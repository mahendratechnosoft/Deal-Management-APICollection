meta {
  name: {{baseUrl}}/{{role}}/getAllReminder?page=1&size=5
  type: http
  seq: 5
}

get {
  url: {{baseUrl}}/{{role}}/getAllReminder?page=0&size=10
  body: json
  auth: bearer
}

params:query {
  page: 0
  size: 10
  ~search: up
  ~startDate: 2026-01-10
  ~endDate: 2026-01-10
}

auth:bearer {
  token: {{bearerToken}}
}

settings {
  encodeUrl: true
  timeout: 0
}
